{
  "name": "sketchbook-ui",
  "version": "1.0.1",
  "description": "A hand-drawn React component library with a unique sketchy, notebook aesthetic",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./dist/style.css": "./dist/sketchbook-ui.css",
    "./style.css": "./dist/sketchbook-ui.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "sideEffects": [
    "*.css"
  ],
  "keywords": [
    "react",
    "components",
    "ui",
    "sketch",
    "hand-drawn",
    "design-system",
    "typescript",
    "tailwind"
  ],
  "author": "SarthakRawat-1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SarthakRawat-1/sketchbook-ui.git"
  },
  "bugs": {
    "url": "https://github.com/SarthakRawat-1/sketchbook-ui/issues"
  },
  "homepage": "https://sarthakrawat-1.github.io/sketchbook-ui/",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "rimraf dist && tsc --project tsconfig.lib.json && vite build --config vite.config.lib.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepublishOnly": "npm run build:lib"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.3.1"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.1",
    "@eslint/js": "^9.36.0",
    "@storybook/addon-a11y": "^9.1.13",
    "@storybook/addon-docs": "^9.1.13",
    "@storybook/addon-onboarding": "^9.1.13",
    "@storybook/addon-vitest": "^9.1.13",
    "@storybook/react-vite": "^9.1.13",
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "eslint-plugin-storybook": "^9.1.13",
    "globals": "^16.4.0",
    "playwright": "^1.56.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "rimraf": "^6.1.3",
    "storybook": "^9.1.13",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0",
    "vite": "^7.1.7",
    "vitest": "^3.2.4"
  }
}
